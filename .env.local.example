# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, never expose to the client.
# Required by the Stripe webhook to update profiles on subscription events.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of the deployed app (used for OAuth redirects + Stripe redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── AI Providers ────────────────────────────────────────────────────────────
# Google API key — used for Lecture Explainer and Roadmap.
# Get one: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Anthropic API key — used for 자소서 critique (Korean nuance is the moat).
# Get one: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenRouter (optional)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=

# ─── Admin dashboard ─────────────────────────────────────────────────────────
# Email that gets access to /admin/feedback (founder feedback dashboard)
ADMIN_EMAIL=

# ─── Stripe (Phase 3 — billing & subscriptions) ──────────────────────────────
# Full walkthrough: STRIPE_SETUP.md
# Server-only secret key (sk_test_… for dev, sk_live_… for prod)
STRIPE_SECRET_KEY=

# Publishable key (safe to expose to client — reserved for future Elements)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Price ID for the Pro monthly plan — create in Stripe Dashboard.
# Must start with `price_` (NOT `prod_` — that's the Product ID).
STRIPE_PRICE_ID_PRO_MONTHLY=

# Signing secret from `stripe listen` (local) or the dashboard webhook (prod)
STRIPE_WEBHOOK_SECRET=
