# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — server-only, never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ─────────────────────────────────────────────────────────────────────
# The public URL of the deployed app (used for OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── AI Provider (Phase 4 — OpenRouter, used for Roadmap) ────────────────────
# OpenRouter API key — server-only
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=anthropic/claude-3-haiku

# ─── Anthropic SDK (Phase 6 — Opus 4.7 + extended thinking) ──────────────────
# Used for: Lecture Explainer, Bug Fixer, Project Generator
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
